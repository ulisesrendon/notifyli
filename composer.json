{
    "name": "ulisesrendon/Chatapp",
    "description": "websocket chat app",
    "type": "project",
    "license": "private",
    "autoload": {
        "psr-4": {
            "Chatapp\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Ulises Rendon",
            "email": "fdulises@outlook.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "vlucas/phpdotenv": "*",
        "paragi/php-websocket-client": "dev-master"
    },
    "scripts": {
        "ws-server": "php -q server.php &",
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "require-dev": {
        "symfony/var-dumper": "7.0.x-dev"
    }
}
