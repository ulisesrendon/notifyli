{
    "name": "neuralpin/notifyli",
    "description": "Websocket communication app",
    "type": "project",
    "license": "private",
    "autoload": {
        "psr-4": {
            "Neuralpin\\Notifyli\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Ulises Rendon",
            "email": "fdulises@outlook.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "vlucas/phpdotenv": "*"
    },
    "scripts": {
        "ws-server": "php -q server.php &",
        "post-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "require-dev": {
        "symfony/var-dumper": "7.0.x-dev",
        "pestphp/pest": "5.x-dev",
        "pestphp/pest-plugin-arch": "5.x-dev"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
